{
	"name": "base",
	"image": "gitlab-master.nvidia.com:5005/sil/flashsim:base-v0.3",
	"runArgs": ["--gpus", "all"],

	// make the user internal to the container not root -> files created in container appear on host as owned by the $USER instead of root
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"username": "vscode"
		}
	},
	"remoteUser": "vscode",
	"containerUser": "vscode",
	"updateRemoteUserUID": true,

	// Create cache directories for uv, huggingface, flashsim, and triton so that mounts do not fail on first run.
	"initializeCommand": "mkdir -p \"${localEnv:HOME}/.cache/uv\" \"${localEnv:HOME}/.cache/huggingface\" \"${localEnv:HOME}/.cache/flashsim\" \"${localEnv:HOME}/.cache/triton\"",
	// Mount local cache directories for speedy operation inside the container.
	"mounts": [
		"source=${localEnv:HOME}/.cache/uv,target=/home/vscode/.cache/uv,type=bind",
		"source=${localEnv:HOME}/.cache/huggingface,target=/home/vscode/.cache/huggingface,type=bind",
		"source=${localEnv:HOME}/.cache/flashsim,target=/home/vscode/.cache/flashsim,type=bind",
		"source=${localEnv:HOME}/.cache/triton,target=/home/vscode/.cache/triton,type=bind"
	],
	"containerEnv": {
		// point to mounted cache directories where they may not coincide with the default
		"HF_HOME": "/home/vscode/.cache/huggingface",
		"TRITON_CACHE_DIR": "/home/vscode/.cache/triton",
		// UV defaults to symlinking to cache dirs, which may not work with mounted volumes
		"UV_LINK_MODE": "copy"
	},
	"postCreateCommand": "uv venv --clear && uv sync --frozen --extra dev"

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Configure tool-specific properties.
	// "customizations": {},
}
